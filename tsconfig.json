{
	"extends": "@react-native/typescript-config",
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "bundler",
		"types": ["jest"],
		"paths": {
			"*":             ["./*"],
			"@/*":           ["./src/*"],
			"@components/*": ["./src/components/*"],
			"@screens/*":    ["./src/screens/*"],
			"@hooks/*":      ["./src/hooks/*"],
			"@utils/*":      ["./src/utils/*"],
			"@assets/*":     ["./src/assets/*"],
			"@navigation/*": ["./src/navigation/*"]
		}
	},
	"include": ["**/*.ts", "**/*.tsx"],
	"exclude": ["**/node_modules", "**/Pods"]
}
